# Frontend Environment Variables

# API Configuration
# For local development: use '/api' (proxied through Vite)
# For production/tunnel: use full URL like 'http://localhost:5002/api'
VITE_API_URL=/api

# Backend API Port (used for tunnel URLs)
# Default: 5002
VITE_API_PORT=5002

# Build configuration
VITE_PREVIEW_PORT=5175
