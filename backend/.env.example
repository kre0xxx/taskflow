# Backend Environment Variables

# Server Port
PORT=5002

# Database Configuration
DB_HOST=localhost
DB_USER=task_user
DB_PASSWORD=task_password
DB_NAME=task_manager
DB_DIALECT=mysql

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_me

# Frontend URL (for CORS)
# For local development, this is auto-detected
# For VSCode tunnel, set it to your tunnel URL
VITE_FRONTEND_URL=http://localhost:5175

# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Node Environment
NODE_ENV=development
