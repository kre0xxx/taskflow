# VSCode Tunnel Configuration
# Copy this to backend/.env and adjust TUNNEL_URL to your actual tunnel URL

# Example for tunnel URLs (replace with your actual tunnel URL):
# yourname.tunnel.vscode.dev

# Backend - .env file content
# PORT=5002
# VITE_FRONTEND_URL=https://yourname.tunnel.vscode.dev

# Frontend - run with tunnel URL
# For local tunnel testing:
# npm run dev -- --host 0.0.0.0

# To connect to remote backend through tunnel:
# Set VITE_API_URL=https://yourname.tunnel.vscode.dev/api
